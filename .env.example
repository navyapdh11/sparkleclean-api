# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sparkleclean?schema=public"

# Redis (BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRES=24h

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (for AI/RAG content generation)
OPENAI_API_KEY=sk-...

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://sparkleclean.com.au

# Server
PORT=3001
NODE_ENV=development
