# Production environment variables for Render
DATABASE_URL=postgresql://user:password@host:5432/sparkleclean?schema=public
REDIS_HOST=your-redis-host.onrender.com
REDIS_PORT=6379
JWT_SECRET=<generate-with: openssl rand -base64 32>
JWT_EXPIRES=24h
PORT=3001
NODE_ENV=production

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Xero (optional — leave blank to disable Xero sync)
XERO_TENANT_ID=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_ACCESS_TOKEN=

# OpenAI (optional — for AI content generation)
OPENAI_API_KEY=

# CORS
ALLOWED_ORIGINS=https://sparkleclean.com.au
